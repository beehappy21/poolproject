generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  BLOCKED
  PENDING
}

enum RiskLevel {
  NORMAL
  WATCH
  HIGH
  CRITICAL
}

enum PayoutStatus {
  ACTIVE
  HOLD
  LOCKED
}

enum AdminRole {
  SUPER_ADMIN
  ADMIN
}

enum PackageStatus {
  ACTIVE
  INACTIVE
}

enum CatalogStatus {
  ACTIVE
  INACTIVE
}

enum PlacementSide {
  LEFT
  RIGHT
}

enum EarningCapType {
  FIXED_AMOUNT
  PRICE_MULTIPLE
}

enum PoolRateMode {
  DEFAULT_50_PERCENT
  CUSTOM_RATE
  DISABLED
}

enum CommissionCapScope {
  POOL_ONLY
  ALL_COMMISSIONS
}

enum CycleStatus {
  ACTIVE
  EXPIRED
  CLOSED
}

enum EarningStatus {
  ACTIVE
  CAPPED
}

enum OrderStatus {
  PENDING
  PAID
  APPROVED
  CANCELLED
  VOIDED
}

enum ApprovalStatus {
  PENDING
  APPROVED
  VOIDED
}

enum ExceptionalReversalStatus {
  NONE
  REQUESTED
  APPROVED
  APPLIED
}

enum CommissionType {
  DIRECT
  UNI
  POOL
  CASHBACK
}

enum CommissionStatus {
  PENDING
  APPROVED
  HELD
  WITHDRAWABLE
  RESERVED_FOR_PAYOUT
  PAID_OUT
  REVERSED
  FALLBACK
}

enum HoldStatus {
  NONE
  HELD
  RELEASED
}

enum CompanyBonusSourceType {
  DIRECT
  UNI
  POOL
  CASHBACK
  REVERSAL
}

enum DailyPoolCycleStatus {
  OPEN
  CLOSED
  ADJUSTED
}

enum WalletTransactionType {
  DIRECT_CREDIT
  UNI_CREDIT
  POOL_CREDIT
  MATRIX_CREDIT
  CASHBACK_CREDIT
  DCW_CREDIT
  COMMISSION_CONVERT_OUT
  SHOPPING_WALLET_CONVERT_IN
  CONVERT_FEE_DEBIT
  WALLET_TRANSFER_OUT
  WALLET_TRANSFER_IN
  TRANSFER_FEE_DEBIT
  TOPUP_CREDIT
  DCW_PURCHASE_DEBIT
  ORDER_PURCHASE_DEBIT
  HOLD_RELEASE
  REVERSAL_DEBIT
  NEGATIVE_OFFSET_APPLY
  PAYOUT_RESERVATION
  PAYOUT_SENT
  PAYOUT_FAILED_REVERT
  MANUAL_ADJUSTMENT
}

enum WalletTransactionDirection {
  CREDIT
  DEBIT
}

enum WalletBalanceBucket {
  APPROVED
  HELD
  WITHDRAWABLE
  SHOPPING
  DISCOUNT
  PAID_OUT
  NEGATIVE_OFFSET
}

enum WalletTopupRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum WalletTransactionStatus {
  POSTED
  REVERSED
}

enum PayoutLockStatus {
  UNLOCKED
  HOLD
  LOCKED
}

enum PayoutBatchStatus {
  DRAFT
  APPROVED
  SUBMITTED
  CONFIRMED
  FAILED
}

enum PayoutBatchItemStatus {
  RESERVED
  SENT
  CONFIRMED
  FAILED
  EXCLUDED
}

enum WalletBindingActionType {
  BIND
  REBIND
  UNBIND
}

enum WalletBindingActionStatus {
  REQUESTED
  VERIFIED
  EFFECTIVE
  REJECTED
  ENDED
}

enum RiskFlagSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum RiskFlagStatus {
  OPEN
  REVIEWING
  CLEARED
  SUPPRESSED
}

enum PayoutHoldScopeType {
  MEMBER
  COMMISSION_ITEM
  POOL_ITEM
  WALLET
}

enum PayoutHoldStatus {
  ACTIVE
  RELEASED
  EXPIRED
  CANCELLED
}

enum ReviewCaseType {
  RISK_REVIEW
  WALLET_REBIND
  PAYOUT_HOLD
  EXCEPTIONAL_REVERSAL
}

enum ReviewCaseStatus {
  OPEN
  ASSIGNED
  RESOLVED
  REJECTED
}

enum ReviewCasePriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum MatrixCycleStatus {
  ACTIVE
  COMPLETED
  RESET
}

enum MatrixBoardStatus {
  LOCKED
  OPEN
  COMPLETED
  RESET
}

enum MatrixPositionStatus {
  FILLED
  RESET
}

enum MatrixPayoutStatus {
  PENDING
  APPROVED
  PAID
  RESET
}

model User {
  id                   BigInt       @id @default(autoincrement())
  memberCode           String       @unique @db.VarChar(50)
  referralCode         String?      @unique @db.VarChar(20)
  name                 String       @db.VarChar(255)
  email                String?      @unique @db.VarChar(255)
  phone                String?      @unique @db.VarChar(50)
  passwordHash         String       @db.VarChar(255)
  walletAddress        String?      @db.VarChar(255)
  walletVerifiedAt     DateTime?
  sponsorId            BigInt?
  status               UserStatus   @default(ACTIVE)
  riskLevel            RiskLevel    @default(NORMAL)
  payoutStatus         PayoutStatus @default(ACTIVE)
  isAdmin              Boolean      @default(false)
  adminRole            AdminRole?
  manualReviewRequired Boolean      @default(false)
  manualReviewReason   String?      @db.VarChar(255)
  lastRiskReviewedAt   DateTime?
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  sponsor                        User?                          @relation("UserSponsorTree", fields: [sponsorId], references: [id])
  directReferrals                User[]                         @relation("UserSponsorTree")
  memberProfile                  MemberProfile?                 @relation("UserMemberProfile")
  memberProfileUplineRefs        MemberProfile[]                @relation("MemberProfileUplineUser")
  packageCycles                  MemberPackageCycle[]
  orders                         Order[]
  beneficiaryCommissions         CommissionLedger[]             @relation("CommissionBeneficiaryUser")
  sourceCommissions              CommissionLedger[]             @relation("CommissionSourceUser")
  originalTargetCommissions      CommissionLedger[]             @relation("CommissionOriginalTargetUser")
  rollupFromCommissions          CommissionLedger[]             @relation("CommissionRollupFromUser")
  companyBonusLedgers            CompanyBonusLedger[]           @relation("CompanyBonusCreatedByUser")
  dailyPoolEligibilitySnapshots  DailyPoolEligibilitySnapshot[]
  dailyPoolPayouts               DailyPoolPayout[]
  wallet                         Wallet?
  walletTransactions             WalletTransaction[]            @relation("WalletTransactionUser")
  counterpartyWalletTransactions WalletTransaction[]            @relation("WalletTransactionCounterpartyUser")
  walletTopupRequests            WalletTopupRequest[]           @relation("WalletTopupRequestUser")
  approvedWalletTopupRequests    WalletTopupRequest[]           @relation("WalletTopupRequestApprovedByUser")
  payoutBatchApprovals           PayoutBatch[]                  @relation("PayoutBatchApprovedByUser")
  payoutBatchSubmissions         PayoutBatch[]                  @relation("PayoutBatchSubmittedByUser")
  payoutBatchReconciliations     PayoutBatch[]                  @relation("PayoutBatchReconciledByUser")
  payoutBatchItems               PayoutBatchItem[]
  walletBindingHistory           WalletBindingHistory[]         @relation("WalletBindingUser")
  walletBindingRequests          WalletBindingHistory[]         @relation("WalletBindingRequestedByUser")
  riskFlags                      MemberRiskFlag[]
  payoutHolds                    PayoutHold[]                   @relation("PayoutHoldUser")
  placedPayoutHolds              PayoutHold[]                   @relation("PayoutHoldPlacedByUser")
  releasedPayoutHolds            PayoutHold[]                   @relation("PayoutHoldReleasedByUser")
  reviewCases                    ManualReviewCase[]             @relation("ManualReviewSubjectUser")
  assignedReviewCases            ManualReviewCase[]             @relation("ManualReviewAssignedUser")
  matrixCycles                   MatrixCycle[]
  matrixSourcePositions          MatrixPosition[]               @relation("MatrixPositionSourceUser")
  matrixBeneficiaryPayouts       MatrixPayout[]                 @relation("MatrixPayoutBeneficiaryUser")
  matrixSourcePayouts            MatrixPayout[]                 @relation("MatrixPayoutSourceUser")
  matrixAccumulationEvents       MatrixAccumulationEvent[]      @relation("MatrixAccumulationSourceUser")
}

model MemberProfile {
  id               BigInt         @id @default(autoincrement())
  userId           BigInt         @unique
  nationalId       String?        @unique @db.VarChar(30)
  uplineUserId     BigInt?
  placementSide    PlacementSide?
  rankCode         String?        @db.VarChar(50)
  honorTitle       String?        @db.VarChar(100)
  mobileCenterCode String?        @db.VarChar(100)
  joinedAtOverride DateTime?      @db.Date
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  user       User  @relation("UserMemberProfile", fields: [userId], references: [id])
  uplineUser User? @relation("MemberProfileUplineUser", fields: [uplineUserId], references: [id])

  @@index([uplineUserId])
  @@index([placementSide])
  @@index([rankCode])
}

model Supplier {
  id          BigInt        @id @default(autoincrement())
  code        String        @unique @db.VarChar(50)
  name        String        @db.VarChar(255)
  slug        String?       @unique @db.VarChar(255)
  description String?       @db.Text
  imageUrl    String?       @db.VarChar(500)
  sortOrder   Int           @default(0)
  isFeatured  Boolean       @default(false)
  status      CatalogStatus @default(ACTIVE)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  categories ProductCategory[]
  products   Product[]
}

model ProductCategory {
  id           BigInt        @id @default(autoincrement())
  supplierId   BigInt
  code         String        @db.VarChar(50)
  name         String        @db.VarChar(255)
  slug         String?       @unique @db.VarChar(255)
  description  String?       @db.Text
  imageUrl     String?       @db.VarChar(500)
  audienceTags String[]      @default([])
  sortOrder    Int           @default(0)
  isFeatured   Boolean       @default(false)
  status       CatalogStatus @default(ACTIVE)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  supplier Supplier  @relation(fields: [supplierId], references: [id])
  products Product[]

  @@unique([supplierId, code])
  @@index([supplierId, status])
}

model Product {
  id          BigInt        @id @default(autoincrement())
  supplierId  BigInt
  categoryId  BigInt
  code        String        @unique @db.VarChar(50)
  name        String        @db.VarChar(255)
  slug        String?       @unique @db.VarChar(255)
  description String?       @db.Text
  sortOrder   Int           @default(0)
  isFeatured  Boolean       @default(false)
  status      CatalogStatus @default(ACTIVE)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  supplier Supplier        @relation(fields: [supplierId], references: [id])
  category ProductCategory @relation(fields: [categoryId], references: [id])
  details  ProductDetail[]

  @@index([supplierId, status])
  @@index([categoryId, status])
}

model ProductDetail {
  id               BigInt        @id @default(autoincrement())
  productId        BigInt
  code             String        @unique @db.VarChar(50)
  name             String        @db.VarChar(255)
  slug             String?       @unique @db.VarChar(255)
  shortDescription String?       @db.VarChar(500)
  description      String?       @db.Text
  youtubeUrl       String?       @db.VarChar(500)
  primaryImageUrl  String?       @db.VarChar(500)
  imageUrls        String[]      @default([])
  costPriceUsdt    Decimal       @default(0) @db.Decimal(18, 8)
  memberPriceUsdt  Decimal       @default(0) @db.Decimal(18, 8)
  retailPriceUsdt  Decimal       @default(0) @db.Decimal(18, 8)
  pv               Decimal       @default(0) @db.Decimal(18, 8)
  ratingAvg        Decimal       @default(0) @db.Decimal(10, 2)
  ratingCount      Int           @default(0)
  sortOrder        Int           @default(0)
  isNew            Boolean       @default(false)
  isTop            Boolean       @default(false)
  isFeatured       Boolean       @default(false)
  isBestSeller     Boolean       @default(false)
  poolRateMode     PoolRateMode   @default(DEFAULT_50_PERCENT)
  poolRate         Decimal       @default(0) @db.Decimal(10, 8)
  poolCapMultiple  Decimal       @default(0) @db.Decimal(10, 8)
  commissionCapScope CommissionCapScope @default(POOL_ONLY)
  commissionCapMultiple Decimal   @default(0) @db.Decimal(10, 8)
  dcwSpendEnabled   Boolean       @default(false)
  dcwUsageAmount    Decimal       @default(0) @db.Decimal(18, 8)
  dcwUsageAmountOverridden Boolean @default(false)
  dcwCashRewardRate Decimal       @default(0) @db.Decimal(10, 8)
  dcwShoppingRewardRate Decimal   @default(0) @db.Decimal(10, 8)
  status           CatalogStatus @default(ACTIVE)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  product      Product       @relation(fields: [productId], references: [id])
  packageItems PackageItem[]

  @@index([productId, status])
}

model Package {
  id               BigInt         @id @default(autoincrement())
  code             String         @unique @db.VarChar(50)
  name             String         @db.VarChar(255)
  costPriceUsdt    Decimal        @default(0) @db.Decimal(18, 8)
  memberPriceUsdt  Decimal        @default(0) @db.Decimal(18, 8)
  retailPriceUsdt  Decimal        @default(0) @db.Decimal(18, 8)
  priceUsdt        Decimal        @db.Decimal(18, 8)
  pv               Decimal        @db.Decimal(18, 8)
  poolRateMode     PoolRateMode   @default(DEFAULT_50_PERCENT)
  poolRate         Decimal        @default(0) @db.Decimal(10, 8)
  poolCapMultiple  Decimal        @default(0) @db.Decimal(10, 8)
  commissionCapScope CommissionCapScope @default(POOL_ONLY)
  commissionCapMultiple Decimal    @default(0) @db.Decimal(10, 8)
  dcwSpendEnabled   Boolean        @default(false)
  dcwUsageAmount    Decimal        @default(0) @db.Decimal(18, 8)
  dcwUsageAmountOverridden Boolean @default(false)
  dcwCashRewardRate Decimal        @default(0) @db.Decimal(10, 8)
  dcwShoppingRewardRate Decimal    @default(0) @db.Decimal(10, 8)
  activeDays       Int
  earningCapType   EarningCapType
  earningCapAmount Decimal        @db.Decimal(18, 8)
  status           PackageStatus  @default(ACTIVE)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  memberPackageCycles MemberPackageCycle[]
  orderItems          OrderItem[]
  packageItems        PackageItem[]
}

model PackageItem {
  id                  BigInt   @id @default(autoincrement())
  packageId           BigInt
  productDetailId     BigInt
  qty                 Int      @default(1)
  unitCostPriceUsdt   Decimal  @default(0) @db.Decimal(18, 8)
  unitMemberPriceUsdt Decimal  @default(0) @db.Decimal(18, 8)
  unitRetailPriceUsdt Decimal  @default(0) @db.Decimal(18, 8)
  unitPv              Decimal  @default(0) @db.Decimal(18, 8)
  unitPoolRate        Decimal  @default(0) @db.Decimal(10, 8)
  lineCostPriceUsdt   Decimal  @default(0) @db.Decimal(18, 8)
  lineMemberPriceUsdt Decimal  @default(0) @db.Decimal(18, 8)
  lineRetailPriceUsdt Decimal  @default(0) @db.Decimal(18, 8)
  linePv              Decimal  @default(0) @db.Decimal(18, 8)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  package       Package       @relation(fields: [packageId], references: [id])
  productDetail ProductDetail @relation(fields: [productDetailId], references: [id])

  @@unique([packageId, productDetailId])
  @@index([productDetailId])
}

model MemberPackageCycle {
  id                 BigInt        @id @default(autoincrement())
  userId             BigInt
  packageId          BigInt
  cycleNo            Int
  activatedAt        DateTime
  activeUntil        DateTime
  earningCap         Decimal       @db.Decimal(18, 8)
  earnedTotalInCycle Decimal       @default(0) @db.Decimal(18, 8)
  earningStatus      EarningStatus @default(ACTIVE)
  repurchaseRequired Boolean       @default(false)
  isReceivable       Boolean       @default(true)
  status             CycleStatus   @default(ACTIVE)
  cappedAt           DateTime?
  closedAt           DateTime?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  user              User               @relation(fields: [userId], references: [id])
  package           Package            @relation(fields: [packageId], references: [id])
  commissionLedgers CommissionLedger[]
  dailyPoolPayouts  DailyPoolPayout[]

  @@unique([userId, cycleNo])
  @@index([userId, status, activatedAt])
  @@index([userId, earningStatus, activeUntil])
  @@index([userId, isReceivable, activatedAt])
}

model Order {
  id                         BigInt                    @id @default(autoincrement())
  orderNo                    String                    @unique @db.VarChar(50)
  userId                     BigInt
  subtotalUsdt               Decimal                   @default(0) @db.Decimal(18, 8)
  totalUsdt                  Decimal                   @default(0) @db.Decimal(18, 8)
  totalPv                    Decimal                   @default(0) @db.Decimal(18, 8)
  dcwAppliedUsdt             Decimal                   @default(0) @db.Decimal(18, 8)
  walletAppliedUsdt          Decimal                   @default(0) @db.Decimal(18, 8)
  cashDueUsdt                Decimal                   @default(0) @db.Decimal(18, 8)
  cashPaymentMethod          String?                   @db.VarChar(100)
  paidAt                     DateTime?
  transferSubmittedAt        DateTime?
  transferSlipUrl            String?                   @db.Text
  transferSlipNote           String?                   @db.Text
  approvedAt                 DateTime?
  shippedAt                  DateTime?
  deliveredAt                DateTime?
  shipmentTrackingNo         String?                   @db.VarChar(100)
  shipmentCarrier            String?                   @db.VarChar(100)
  shipmentNote               String?                   @db.Text
  refundWindowEndsAt         DateTime?
  approvalBatchRef           String?                   @db.VarChar(100)
  commissionSettingsSnapshot String?                   @db.Text
  matrixSettingsSnapshot     String?                   @db.Text
  approvalStatus             ApprovalStatus            @default(PENDING)
  exceptionalReversalStatus  ExceptionalReversalStatus @default(NONE)
  status                     OrderStatus               @default(PENDING)
  createdAt                  DateTime                  @default(now())
  updatedAt                  DateTime                  @updatedAt

  user                     User                      @relation(fields: [userId], references: [id])
  orderItems               OrderItem[]
  commissionLedgers        CommissionLedger[]
  matrixSourcePositions    MatrixPosition[]          @relation("MatrixPositionSourceOrder")
  matrixPayouts            MatrixPayout[]            @relation("MatrixPayoutSourceOrder")
  matrixAccumulationEvents MatrixAccumulationEvent[] @relation("MatrixAccumulationSourceOrder")

  @@index([userId, status])
  @@index([approvedAt])
  @@index([approvalStatus])
  @@index([transferSubmittedAt])
  @@index([shippedAt])
  @@index([deliveredAt])
}

model OrderItem {
  id            BigInt   @id @default(autoincrement())
  orderId       BigInt
  packageId     BigInt?
  productId     String?  @db.VarChar(100)
  qty           Int      @default(1)
  unitPriceUsdt Decimal  @default(0) @db.Decimal(18, 8)
  unitPv        Decimal  @default(0) @db.Decimal(18, 8)
  poolRateMode  PoolRateMode @default(DEFAULT_50_PERCENT)
  unitPoolRate  Decimal  @default(0) @db.Decimal(10, 8)
  dcwSpendEnabled Boolean @default(false)
  unitDcwUsageAmount Decimal @default(0) @db.Decimal(18, 8)
  unitDcwCashRewardRate Decimal @default(0) @db.Decimal(10, 8)
  unitDcwShoppingRewardRate Decimal @default(0) @db.Decimal(10, 8)
  lineTotalUsdt Decimal  @default(0) @db.Decimal(18, 8)
  lineTotalPv   Decimal  @default(0) @db.Decimal(18, 8)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  order   Order    @relation(fields: [orderId], references: [id])
  package Package? @relation(fields: [packageId], references: [id])

  @@index([orderId])
}

model CommissionLedger {
  id                       BigInt           @id @default(autoincrement())
  beneficiaryUserId        BigInt?
  beneficiaryCycleId       BigInt?
  sourceUserId             BigInt
  orderId                  BigInt?
  commissionType           CommissionType
  tierNo                   Int?
  levelNo                  Int?
  rate                     Decimal          @default(0) @db.Decimal(10, 8)
  basePv                   Decimal          @default(0) @db.Decimal(18, 8)
  commissionAmount         Decimal          @default(0) @db.Decimal(18, 8)
  originalTargetUserId     BigInt?
  rollupFromUserId         BigInt?
  rollupDepth              Int              @default(0)
  cycleRefId               BigInt?
  evaluationAt             DateTime
  finalizeCheckedAt        DateTime?
  finalizedAt              DateTime?
  status                   CommissionStatus @default(PENDING)
  fallbackToCompany        Boolean          @default(false)
  blockReason              String?          @db.VarChar(100)
  companyFallbackReason    String?          @db.VarChar(100)
  holdStatus               HoldStatus       @default(NONE)
  holdReason               String?          @db.VarChar(100)
  releasedToWithdrawableAt DateTime?
  createdAt                DateTime         @default(now())
  updatedAt                DateTime         @updatedAt

  beneficiaryUser    User?               @relation("CommissionBeneficiaryUser", fields: [beneficiaryUserId], references: [id])
  beneficiaryCycle   MemberPackageCycle? @relation(fields: [beneficiaryCycleId], references: [id])
  sourceUser         User                @relation("CommissionSourceUser", fields: [sourceUserId], references: [id])
  order              Order?              @relation(fields: [orderId], references: [id])
  originalTargetUser User?               @relation("CommissionOriginalTargetUser", fields: [originalTargetUserId], references: [id])
  rollupFromUser     User?               @relation("CommissionRollupFromUser", fields: [rollupFromUserId], references: [id])
  dailyPoolPayouts   DailyPoolPayout[]

  @@index([beneficiaryUserId, status])
  @@index([beneficiaryCycleId, status])
  @@index([orderId, commissionType])
  @@index([status, holdStatus])
  @@index([cycleRefId])
}

model CompanyBonusLedger {
  id              BigInt                 @id @default(autoincrement())
  sourceType      CompanyBonusSourceType
  sourceRefId     BigInt
  bonusType       CommissionType
  amount          Decimal                @default(0) @db.Decimal(18, 8)
  reason          String                 @db.VarChar(100)
  createdByUserId BigInt?
  createdAt       DateTime               @default(now())

  createdByUser User? @relation("CompanyBonusCreatedByUser", fields: [createdByUserId], references: [id])

  @@index([sourceType, sourceRefId])
  @@index([reason])
}

model DailyPoolCycle {
  id                        BigInt               @id @default(autoincrement())
  cycleDate                 DateTime             @db.Date
  snapshotAt                DateTime
  evaluationAt              DateTime             @default(now())
  totalPv                   Decimal              @default(0) @db.Decimal(18, 8)
  fundingApprovedOrderCount Int                  @default(0)
  fundingTotalApprovedPv    Decimal              @default(0) @db.Decimal(18, 8)
  poolRate                  Decimal              @default(0.5) @db.Decimal(10, 8)
  settingsSnapshot          String?              @db.Text
  poolFund                  Decimal              @default(0) @db.Decimal(18, 8)
  eligibleMemberCount       Int                  @default(0)
  payoutPerMember           Decimal              @default(0) @db.Decimal(18, 8)
  companyFallbackAmount     Decimal              @default(0) @db.Decimal(18, 8)
  status                    DailyPoolCycleStatus @default(OPEN)
  createdAt                 DateTime             @default(now())
  updatedAt                 DateTime             @updatedAt

  eligibilitySnapshots DailyPoolEligibilitySnapshot[]
  dailyPoolPayouts     DailyPoolPayout[]

  @@unique([cycleDate])
  @@index([status])
}

model DailyPoolEligibilitySnapshot {
  id                        BigInt   @id @default(autoincrement())
  cycleId                   BigInt
  userId                    BigInt
  isMemberActive            Boolean  @default(false)
  activeDirectReferralCount Int      @default(0)
  isEligible                Boolean  @default(false)
  reason                    String?  @db.VarChar(100)
  createdAt                 DateTime @default(now())

  cycle DailyPoolCycle @relation(fields: [cycleId], references: [id])
  user  User           @relation(fields: [userId], references: [id])

  @@unique([cycleId, userId])
  @@index([cycleId, isEligible])
}

model DailyPoolPayout {
  id                 BigInt           @id @default(autoincrement())
  cycleId            BigInt
  userId             BigInt
  beneficiaryCycleId BigInt?
  commissionLedgerId BigInt?
  payoutAmount       Decimal          @default(0) @db.Decimal(18, 8)
  status             CommissionStatus @default(PENDING)
  blockReason        String?          @db.VarChar(100)
  holdStatus         HoldStatus       @default(NONE)
  holdReason         String?          @db.VarChar(100)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  cycle            DailyPoolCycle      @relation(fields: [cycleId], references: [id])
  user             User                @relation(fields: [userId], references: [id])
  beneficiaryCycle MemberPackageCycle? @relation(fields: [beneficiaryCycleId], references: [id])
  commissionLedger CommissionLedger?   @relation(fields: [commissionLedgerId], references: [id])

  @@index([cycleId, status])
  @@index([userId, status])
}

model Wallet {
  id                    BigInt           @id @default(autoincrement())
  userId                BigInt           @unique
  approvedBalance       Decimal          @default(0) @db.Decimal(18, 8)
  heldBalance           Decimal          @default(0) @db.Decimal(18, 8)
  withdrawableBalance   Decimal          @default(0) @db.Decimal(18, 8)
  shoppingBalance       Decimal          @default(0) @db.Decimal(18, 8)
  discountBalance       Decimal          @default(0) @db.Decimal(18, 8)
  paidOutBalance        Decimal          @default(0) @db.Decimal(18, 8)
  negativeOffsetBalance Decimal          @default(0) @db.Decimal(18, 8)
  payoutLockStatus      PayoutLockStatus @default(UNLOCKED)
  payoutLockReason      String?          @db.VarChar(255)
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model WalletTransaction {
  id                 BigInt                     @id @default(autoincrement())
  userId             BigInt
  txType             WalletTransactionType
  direction          WalletTransactionDirection
  balanceBucket      WalletBalanceBucket
  refType            String                     @db.VarChar(50)
  refId              BigInt
  counterpartyUserId BigInt?
  note               String?                    @db.VarChar(255)
  amount             Decimal                    @default(0) @db.Decimal(18, 8)
  status             WalletTransactionStatus    @default(POSTED)
  createdAt          DateTime                   @default(now())
  updatedAt          DateTime                   @updatedAt

  user             User  @relation("WalletTransactionUser", fields: [userId], references: [id])
  counterpartyUser User? @relation("WalletTransactionCounterpartyUser", fields: [counterpartyUserId], references: [id])

  @@index([userId, createdAt])
  @@index([refType, refId])
  @@index([balanceBucket, status])
}

model WalletTopupRequest {
  id               BigInt                   @id @default(autoincrement())
  userId           BigInt
  amount           Decimal                  @default(0) @db.Decimal(18, 8)
  paymentMethod    String                   @db.VarChar(100)
  transferSlipUrl  String?                  @db.Text
  note             String?                  @db.Text
  status           WalletTopupRequestStatus @default(PENDING)
  requestedAt      DateTime                 @default(now())
  approvedAt       DateTime?
  approvedByUserId BigInt?
  rejectionReason  String?                  @db.Text
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt

  user           User  @relation("WalletTopupRequestUser", fields: [userId], references: [id])
  approvedByUser User? @relation("WalletTopupRequestApprovedByUser", fields: [approvedByUserId], references: [id])

  @@index([userId, status, requestedAt])
  @@index([status, requestedAt])
  @@index([approvedByUserId])
}

model MatrixCycle {
  id                 BigInt            @id @default(autoincrement())
  userId             BigInt
  cycleNo            Int
  boardWidth         Int               @default(2)
  boardDepth         Int               @default(3)
  boardCount         Int               @default(3)
  organizationPvRate Decimal           @default(0.1) @db.Decimal(10, 8)
  levelRatesSnapshot String            @default("[\"0.1\",\"0.05\",\"0.03\"]") @db.Text
  totalAccumulatedPv Decimal           @default(0) @db.Decimal(18, 8)
  currentBoardNo     Int               @default(1)
  status             MatrixCycleStatus @default(ACTIVE)
  startedAt          DateTime          @default(now())
  completedAt        DateTime?
  resetAt            DateTime?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  user               User                      @relation(fields: [userId], references: [id])
  boards             MatrixBoard[]
  payouts            MatrixPayout[]
  accumulationEvents MatrixAccumulationEvent[]

  @@unique([userId, cycleNo])
  @@index([userId, status])
}

model MatrixBoard {
  id              BigInt            @id @default(autoincrement())
  cycleId         BigInt
  boardNo         Int
  slotCount       Int               @default(14)
  openThresholdPv Decimal           @default(0) @db.Decimal(18, 8)
  accumulatedPv   Decimal           @default(0) @db.Decimal(18, 8)
  filledSlots     Int               @default(0)
  status          MatrixBoardStatus @default(LOCKED)
  openedAt        DateTime?
  completedAt     DateTime?
  resetAt         DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  cycle              MatrixCycle               @relation(fields: [cycleId], references: [id])
  positions          MatrixPosition[]
  payouts            MatrixPayout[]
  accumulationEvents MatrixAccumulationEvent[]

  @@unique([cycleId, boardNo])
  @@index([cycleId, status])
}

model MatrixPosition {
  id            BigInt               @id @default(autoincrement())
  boardId       BigInt
  slotNo        Int
  levelNo       Int
  parentSlotNo  Int?
  sourceUserId  BigInt?
  sourceOrderId BigInt?
  sourcePv      Decimal              @default(0) @db.Decimal(18, 8)
  creditedPv    Decimal              @default(0) @db.Decimal(18, 8)
  status        MatrixPositionStatus @default(FILLED)
  assignedAt    DateTime             @default(now())
  resetAt       DateTime?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  board       MatrixBoard    @relation(fields: [boardId], references: [id])
  sourceUser  User?          @relation("MatrixPositionSourceUser", fields: [sourceUserId], references: [id])
  sourceOrder Order?         @relation("MatrixPositionSourceOrder", fields: [sourceOrderId], references: [id])
  payouts     MatrixPayout[]

  @@unique([boardId, slotNo])
  @@index([boardId, levelNo])
  @@index([sourceUserId])
  @@index([sourceOrderId])
}

model MatrixPayout {
  id                BigInt             @id @default(autoincrement())
  cycleId           BigInt
  boardId           BigInt
  positionId        BigInt?
  beneficiaryUserId BigInt
  sourceUserId      BigInt?
  sourceOrderId     BigInt?
  boardNo           Int
  levelNo           Int
  rate              Decimal            @default(0) @db.Decimal(10, 8)
  basePv            Decimal            @default(0) @db.Decimal(18, 8)
  payoutAmount      Decimal            @default(0) @db.Decimal(18, 8)
  status            MatrixPayoutStatus @default(PENDING)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  cycle           MatrixCycle     @relation(fields: [cycleId], references: [id])
  board           MatrixBoard     @relation(fields: [boardId], references: [id])
  position        MatrixPosition? @relation(fields: [positionId], references: [id])
  beneficiaryUser User            @relation("MatrixPayoutBeneficiaryUser", fields: [beneficiaryUserId], references: [id])
  sourceUser      User?           @relation("MatrixPayoutSourceUser", fields: [sourceUserId], references: [id])
  sourceOrder     Order?          @relation("MatrixPayoutSourceOrder", fields: [sourceOrderId], references: [id])

  @@index([cycleId, status])
  @@index([boardId, levelNo])
  @@index([beneficiaryUserId, status])
  @@index([sourceOrderId])
}

model MatrixAccumulationEvent {
  id            BigInt   @id @default(autoincrement())
  cycleId       BigInt
  boardId       BigInt?
  sourceUserId  BigInt
  sourceOrderId BigInt?
  depthNo       Int
  sourcePv      Decimal  @default(0) @db.Decimal(18, 8)
  creditedPv    Decimal  @default(0) @db.Decimal(18, 8)
  createdAt     DateTime @default(now())

  cycle       MatrixCycle  @relation(fields: [cycleId], references: [id])
  board       MatrixBoard? @relation(fields: [boardId], references: [id])
  sourceUser  User         @relation("MatrixAccumulationSourceUser", fields: [sourceUserId], references: [id])
  sourceOrder Order?       @relation("MatrixAccumulationSourceOrder", fields: [sourceOrderId], references: [id])

  @@index([cycleId, createdAt])
  @@index([boardId, createdAt])
  @@index([sourceUserId, createdAt])
}

model PayoutBatch {
  id                 BigInt            @id @default(autoincrement())
  batchNo            String            @unique @db.VarChar(50)
  totalAmount        Decimal           @default(0) @db.Decimal(18, 8)
  itemCount          Int               @default(0)
  chainId            String            @db.VarChar(50)
  tokenAddress       String            @db.VarChar(255)
  approvedByUserId   BigInt?
  submittedByUserId  BigInt?
  reconciledByUserId BigInt?
  riskSnapshotRef    String?           @db.VarChar(100)
  submittedTxHash    String?           @db.VarChar(255)
  submittedAt        DateTime?
  confirmedAt        DateTime?
  status             PayoutBatchStatus @default(DRAFT)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  approvedByUser   User?             @relation("PayoutBatchApprovedByUser", fields: [approvedByUserId], references: [id])
  submittedByUser  User?             @relation("PayoutBatchSubmittedByUser", fields: [submittedByUserId], references: [id])
  reconciledByUser User?             @relation("PayoutBatchReconciledByUser", fields: [reconciledByUserId], references: [id])
  payoutBatchItems PayoutBatchItem[]

  @@index([status])
}

model PayoutBatchItem {
  id             BigInt                @id @default(autoincrement())
  batchId        BigInt
  userId         BigInt
  walletAddress  String                @db.VarChar(255)
  amount         Decimal               @default(0) @db.Decimal(18, 8)
  refType        String                @db.VarChar(50)
  refId          BigInt
  holdClearedAt  DateTime?
  excludedReason String?               @db.VarChar(100)
  txHash         String?               @db.VarChar(255)
  status         PayoutBatchItemStatus @default(RESERVED)
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  batch PayoutBatch @relation(fields: [batchId], references: [id])
  user  User        @relation(fields: [userId], references: [id])

  @@index([batchId, status])
  @@index([userId, status])
}

model WalletBindingHistory {
  id                   BigInt                    @id @default(autoincrement())
  userId               BigInt
  walletAddress        String                    @db.VarChar(255)
  actionType           WalletBindingActionType
  actionStatus         WalletBindingActionStatus
  signatureNonce       String?                   @db.VarChar(255)
  signaturePayloadHash String?                   @db.VarChar(255)
  requestedAt          DateTime
  verifiedAt           DateTime?
  effectiveAt          DateTime?
  endedAt              DateTime?
  requestedByUserId    BigInt?
  reviewCaseId         BigInt?
  reason               String?                   @db.VarChar(255)
  createdAt            DateTime                  @default(now())

  user            User              @relation("WalletBindingUser", fields: [userId], references: [id])
  requestedByUser User?             @relation("WalletBindingRequestedByUser", fields: [requestedByUserId], references: [id])
  reviewCase      ManualReviewCase? @relation(fields: [reviewCaseId], references: [id])

  @@index([userId])
  @@index([walletAddress])
  @@index([actionStatus])
}

model MemberRiskFlag {
  id          BigInt           @id @default(autoincrement())
  userId      BigInt
  flagType    String           @db.VarChar(50)
  severity    RiskFlagSeverity
  status      RiskFlagStatus   @default(OPEN)
  score       Decimal?         @db.Decimal(10, 2)
  detectedAt  DateTime
  clearedAt   DateTime?
  source      String           @db.VarChar(50)
  detailsJson Json
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([userId, status])
  @@index([flagType, status])
  @@index([severity, status])
}

model PayoutHold {
  id               BigInt              @id @default(autoincrement())
  userId           BigInt
  scopeType        PayoutHoldScopeType
  scopeRefId       BigInt?
  reasonCode       String              @db.VarChar(100)
  status           PayoutHoldStatus    @default(ACTIVE)
  placedAt         DateTime
  releasedAt       DateTime?
  placedByUserId   BigInt
  releasedByUserId BigInt?
  reviewCaseId     BigInt?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  user           User              @relation("PayoutHoldUser", fields: [userId], references: [id])
  placedByUser   User              @relation("PayoutHoldPlacedByUser", fields: [placedByUserId], references: [id])
  releasedByUser User?             @relation("PayoutHoldReleasedByUser", fields: [releasedByUserId], references: [id])
  reviewCase     ManualReviewCase? @relation(fields: [reviewCaseId], references: [id])

  @@index([userId, status])
  @@index([scopeType, scopeRefId])
}

model ManualReviewCase {
  id               BigInt             @id @default(autoincrement())
  caseType         ReviewCaseType
  userId           BigInt
  status           ReviewCaseStatus   @default(OPEN)
  priority         ReviewCasePriority @default(NORMAL)
  openedAt         DateTime
  assignedToUserId BigInt?
  resolvedAt       DateTime?
  resolutionCode   String?            @db.VarChar(100)
  resolutionNotes  String?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  user                 User                   @relation("ManualReviewSubjectUser", fields: [userId], references: [id])
  assignedToUser       User?                  @relation("ManualReviewAssignedUser", fields: [assignedToUserId], references: [id])
  walletBindingHistory WalletBindingHistory[]
  payoutHolds          PayoutHold[]

  @@index([userId, status])
  @@index([caseType, status])
}
