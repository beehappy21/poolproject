{
  "name": "web3-ecommerce-referral-platform",
  "private": true,
  "version": "0.1.0",
  "description": "Production-oriented NestJS monorepo scaffold for a Web3-enabled eCommerce referral platform.",
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "build": "nest build api && nest build worker",
    "dev:api": "nest start api --watch",
    "dev:api:retest": "bash scripts/run_local_api_retest.sh",
    "dev:worker": "nest start worker --watch",
    "dev:up": "bash scripts/dev-up.sh",
    "dev:restart": "bash scripts/dev-restart.sh",
    "wap:refresh": "bash scripts/wap-refresh-verify.sh",
    "dev:check": "bash scripts/dev-check.sh",
    "ops:check:api-env": "node scripts/check_api_env.mjs",
    "ops:check:bao-env": "node scripts/check_bao_env.mjs",
    "ops:check:wap-env": "node scripts/check_wap_env.mjs",
    "ops:check:stephub-tree": "bash scripts/check_stephub_source_tree.sh",
    "ops:check:deploy-env": "node scripts/check_api_env.mjs deploy/compose/api.env.example && node scripts/check_bao_env.mjs deploy/compose/bao.env.example && node scripts/check_wap_env.mjs deploy/compose/wap.env.example",
    "ops:check:compose-stack": "bash scripts/check_compose_stack.sh",
    "ops:check:public-urls": "bash scripts/check_public_urls.sh",
    "ops:init:compose-env": "bash scripts/init_compose_env.sh",
    "ops:prepare:commission-runtime-release": "bash scripts/prepare_commission_runtime_release.sh",
    "ops:check:secrets": "node scripts/check_secret_placeholders.mjs",
    "ops:preflight:deploy": "bash scripts/preflight_deploy_check.sh",
    "dev:check:public-auth": "bash scripts/check_public_auth_bridge.sh",
    "ops:pr:update-description": "bash scripts/update_pr_description_with_retry.sh",
    "dev:backup": "bash scripts/create_local_backup.sh",
    "uat:backup": "bash scripts/create_uat_backup.sh",
    "uat:restore": "bash scripts/restore_uat_backup.sh",
    "reset:runtime:retest": "node scripts/reset_retest_runtime.mjs",
    "ops:cleanup:test-artifacts": "bash scripts/cleanup_runtime_test_artifacts.sh",
    "ops:cleanup:test-artifacts:apply": "bash scripts/cleanup_runtime_test_artifacts.sh --apply",
    "dev:launchd:install": "bash scripts/install_local_stack_launch_agents.sh",
    "dev:launchd:status": "bash scripts/local_stack_launch_agents_status.sh",
    "dev:launchd:uninstall": "bash scripts/uninstall_local_stack_launch_agents.sh",
    "dev:baseline:stephub": "bash scripts/ensure-stephub-local-state.sh",
    "dev:check:stephub": "bash scripts/check-stephub-local-baseline.sh",
    "start:api": "nest start api",
    "start:worker": "nest start worker",
    "lint": "tsc --noEmit -p apps/api/tsconfig.app.json && tsc --noEmit -p apps/worker/tsconfig.app.json",
    "test": "pnpm run lint",
    "prisma:generate": "prisma generate --schema prisma/schema.prisma",
    "prisma:format": "prisma format --schema prisma/schema.prisma",
    "prisma:push": "prisma db push --schema prisma/schema.prisma",
    "db:bootstrap:retest": "node scripts/bootstrap_retest_db.mjs",
    "line:bindings:migrate-runtime": "node scripts/migrate_line_bindings_runtime_to_db.mjs",
    "db:seed": "node scripts/seed-dev.js",
    "smoke:local": "bash scripts/local-smoke.sh",
    "smoke:cashback": "node scripts/cashback-smoke.js",
    "smoke:firm": "node scripts/firm-wallet-smoke.js",
    "smoke:orders:create": "node scripts/order-creation-smoke.js",
    "smoke:bao:promotion": "node scripts/bao-product-promotion-smoke.js",
    "ops:configure:bao:promotion-100pv": "node scripts/configure_bao_promotion_100pv.js",
    "smoke:orders:approve-commission": "node scripts/approve-order-commission-smoke.js",
    "smoke:matrix:by-code": "node scripts/matrix-by-code-smoke.js",
    "smoke:matrix:spill": "node scripts/matrix-spill-smoke.js",
    "smoke:commissions:team-carry-forward": "node scripts/team-carry-forward-smoke.js",
    "smoke:commissions:team-matching-final-payable": "node scripts/team-matching-final-payable-smoke.js",
    "smoke:commissions:team-concurrent-rerun": "node scripts/team-concurrent-rerun-smoke.js",
    "smoke:pool:cap": "bash scripts/pool-cap-local-smoke.sh",
    "smoke:pool:rules": "bash scripts/pool-config-rules-local-smoke.sh",
    "smoke:pool:all-comm-e2e": "bash scripts/pool-all-commissions-e2e-smoke.sh",
    "smoke:pool:weekly": "bash scripts/pool-weekly-local-smoke.sh",
    "smoke:pool:all": "bash scripts/pool-all-smoke.sh",
    "smoke:wallet:mixed": "bash scripts/wallet-mixed-payment-smoke.sh",
    "smoke:wallet:dcw": "bash scripts/discount-wallet-smoke.sh",
    "smoke:cap:foundation": "node scripts/cap-phase-foundation-smoke.js",
    "smoke:bao:cashback": "bash scripts/check_stephub_admin_cashback_report.sh",
    "smoke:bao:withdraw-kyc": "bash scripts/check_stephub_admin_withdraw_kyc.sh",
    "smoke:bao:shipment": "bash scripts/check_stephub_order_shipment_flow.sh",
    "smoke:bao:all": "bash scripts/run_bao_browser_checks.sh",
    "smoke:wap:surface": "node scripts/check_wap_public_surface.js",
    "wap:verify": "bash scripts/wap-refresh-verify.sh --verify-only",
    "seed:members:random-referrals": "node scripts/seed_random_referral_members.js",
    "seed:members:random-referrals:rebalance": "node scripts/rebalance_random_referral_members.js",
    "test:commissions:summary": "node scripts/query_commission_runtime_summary.js",
    "test:commissions:member003-baseline": "node scripts/seed_member003_test_baseline.js",
    "test:wap:promotion-100pv": "node scripts/wap-promotion-commission-check.js",
    "cleanup:commissions:member003-baseline-runtime": "node scripts/backfills/cleanup-commission-test-baseline-runtime.js",
    "test:matrix:legacy-benchmarks": "bash scripts/run_member003_matrix_legacy_benchmarks.sh",
    "test:matrix:runtime-benchmarks": "bash scripts/run_member003_matrix_runtime_benchmarks.sh",
    "cleanup:cashback-smoke": "node scripts/backfills/cleanup-cashback-smoke-artifacts.js",
    "calc:scenarios": "bash scripts/calc-scenarios.sh",
    "reset:local:members-sales": "node scripts/reset_local_members_and_sales.mjs",
    "reset:local:members-sales:apply": "ALLOW_DESTRUCTIVE_LOCAL_RESET=1 node scripts/reset_local_members_and_sales.mjs --apply",
    "ops:reset:transactions:keep-members-catalog": "node scripts/reset_server_transactions_keep_members_catalog.mjs",
    "ops:reset:transactions:keep-members-catalog:apply": "ALLOW_DESTRUCTIVE_UAT_RESET=1 node scripts/reset_server_transactions_keep_members_catalog.mjs --apply",
    "ops:prepare:full-reset-deploy-bundle": "bash scripts/prepare_full_reset_deploy_bundle.sh",
    "rebuild:member003:agents-only": "node scripts/rebuild_member003_agents_only.mjs member003.xlsx 123456",
    "rebuild:member003:agents-only:apply": "ALLOW_DESTRUCTIVE_LOCAL_RESET=1 node scripts/rebuild_member003_agents_only.mjs member003.xlsx 123456 --apply",
    "reconcile:member-code:id": "node scripts/reconcile_member_code_to_id.mjs",
    "reconcile:member-code:id:apply": "ALLOW_DESTRUCTIVE_LOCAL_RESET=1 node scripts/reconcile_member_code_to_id.mjs --apply",
    "seed:members:member003": "node scripts/seed_members_from_xlsx.mjs member003.xlsx",
    "seed:members:member003:apply": "node scripts/seed_members_from_xlsx.mjs member003.xlsx 123456 --apply",
    "validate:members:lmr": "node scripts/validate_member_tree_lmr.mjs",
    "fill:members:profiles:member003": "node scripts/fill_member_profiles_from_member003.mjs member003.xlsx",
    "fill:members:profiles:member003:apply": "ALLOW_DESTRUCTIVE_LOCAL_RESET=1 node scripts/fill_member_profiles_from_member003.mjs member003.xlsx --apply",
    "rebalance:members:placement": "node scripts/rebalance_member_placement_from_sponsor.mjs",
    "rebalance:members:placement:apply": "ALLOW_DESTRUCTIVE_LOCAL_RESET=1 node scripts/rebalance_member_placement_from_sponsor.mjs --apply"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.15",
    "@nestjs/core": "^10.4.15",
    "@nestjs/platform-express": "^10.4.15",
    "@prisma/client": "^5.17.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "@types/node": "^20.17.10",
    "prisma": "^5.17.0",
    "typescript": "^5.4.5"
  },
  "workspaces": [
    "apps/*",
    "packages/*",
    "packages/modules/*"
  ]
}
